{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "strict": true,
    "outDir": "./dist",
    "baseUrl": ".",
    "paths": {
      "../../lib/*": ["../lib/*"]
    }
  },
  "include": ["**/*.ts", "../lib/**/*.ts"],
  "exclude": ["node_modules"]
}
